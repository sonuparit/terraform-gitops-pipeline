# Permissions to IAM user to create EKS
AdministratorAccess

# Permissions to IAM user to create and push to ECR
AmazonEC2ContainerRegistryFullAccess
AmazonElasticContainerRegistryPublicPowerUser

# Variables used in CI Pipeline
AWS_ACCESS_KEY_ID	    :
AWS_SECRET_ACCESS_KEY	:
AWS_ACCOUNT_ID		    :
AWS_REGION			      :

# aws cli config
aws eks update-kubeconfig --region ap-south-1 --name <your-cluster-name>

# Patch The Svc
kubectl patch svc argocd-server -n argocd -p '{"spec": {"type": "LoadBalancer"}}'

# ArgoCD Initial passwd:
kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d; echo


# This shows ONLY the values that differ from the default chart
helm get values <release-name> -n <namespace>